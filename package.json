{
  "name": "kimiko-discord",
  "version": "0.0.1-indev",
  "description": "Kimiko is a self-hostable and fully modular plugin-based discord bot.",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "start": "node dist/index.js",
    "build": "tsc",
    "dev": "tsc-watch --onSuccess \"node dist/index.js\"",
    "format": "prettier --write .",
    "generate": "node ./cli"
  },
  "keywords": [
    "bot",
    "discord",
    "plugins",
    "modular",
    "anime",
    "kimiko"
  ],
  "author": "syntaxbullet",
  "license": "GPL-3.0",
  "devDependencies": {
    "@types/dotenv": "^8.2.0",
    "@types/node": "^20.14.2",
    "prettier": "3.3.1",
    "ts-node": "^10.9.2",
    "tsc-watch": "^6.2.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.4.5"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "discord.js": "^14.15.3",
    "dotenv": "^16.4.5",
    "zod": "^3.23.8"
  }
}
