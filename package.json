  "description": "Kimiko is a self-hostable and fully modular plugin-based discord bot.",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node -r tsconfig-paths/register src/index.ts",
    "format": "prettier --write .",
    "generate": "node ./cli"
  },
  "keywords": [
    "bot",
    "discord",
    "plugins",
    "modular",
    "anime",
    "kimiko"
  ],
  "author": "syntaxbullet",
  "license": "GPL-3.0",
  "devDependencies": {
    "@kimikobot/cli": "file:cli",
    "@kimikobot/types": "file:types",
    "@types/dotenv": "^8.2.0",
    "@types/node": "^20.14.2",
    "install": "0.13.0",
    "npm": "10.8.1",
    "prettier": "3.3.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.4.5"
  },
  "dependencies": {
    "discord.js": "^14.15.3",
    "dotenv": "^16.4.5",
    "myplugindependant": "file:plugins/myplugindependant"
  }
