{
  "loggingDefaults": {
    "logToConsole": true,
    "logToFile": false,
    "logFilePath": "logs",
    "logFileName": "kimiko.log",
    "includeTimestamps": true,
    "timestampFormat": "de-DE",
    "includeLogLevel": false,
    "enabledLogLevels": ["DEBUG", "INFO", "WARN", "ERROR"],
    "logLevelColors": {
      "DEBUG": "00FFFF",
      "INFO": "00FF00",
      "WARN": "FFFF00",
      "ERROR": "FF0000"
    }
  },
  "intents": ["Guilds", "GuildMessages", "GuildMembers", "MessageContent"]
}
